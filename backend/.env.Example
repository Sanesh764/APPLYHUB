
PORT=your port no
MONGODB_URI=your url
# ==============================================================================
# AI CONFIGURATION
# ==============================================================================
# The Gemini API is recommended for free-tier usage, fast response times, and
# structured JSON outputs. Get a key from Google AI Studio.
NVIDIA_API_KEY=YOUR API
AI_PROVIDER=nvidia


MOONSHOT_API_KEY=YOUR API KEY
MOONSHOT_MODEL=moonshotai/kimi-k2.6

# AI Provider
AI_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=YOUR API KEY
DEEPSEEK_MODEL=deepseek-chat
# Alternatively, if you prefer to use OpenAI's models:
# OPENAI_API_KEY=your_openai_api_key_here

# ==============================================================================
# CLOUDINARY CONFIGURATION (Cloud Storage)
# ==============================================================================
# Used to store resume files in the cloud. If these are missing, the system
# will run in local-filesystem mode, saving files to "backend/uploads/" and
# serving them locally.
CLOUDINARY_CLOUD_NAME=CLOUD NAME
CLOUDINARY_API_KEY=CLOUD KEY
CLOUDINARY_API_SECRET=CLOUD API SECRET

# ==============================================================================
# SMTP CONFIGURATION (Email Notifications)
# ==============================================================================
# Needed for sending daily automation matching summaries, alerts, and reminders.
# If missing, email content prints directly to the Winston console logs.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR EMAIL
SMTP_PASS=YOUR KEY
SMTP_FROM=WHERE YOU WANT TO SEND EMAIL


# rwnd cjkd tytr cqqg

# ==============================================================================
# JOB PROVIDER CONFIGURATION
# ==============================================================================
# The live aggregator pulls from multiple public job sources. Providers whose
# configuration is missing are simply skipped at startup — the rest still work.

# Adzuna (requires credentials). Country codes are ISO-2, comma-separated.
ADZUNA_APP_ID=APP ID
ADZUNA_APP_KEY=APP KEY
ADZUNA_COUNTRIES=in,us,gb

# ATS board / company handles to pull from (comma-separated). Optional — each
# has sensible public defaults. A user's "company" search filter overrides these.
GREENHOUSE_BOARDS=stripe,figma,gitlab,coinbase,dropbox
LEVER_BOARDS=netflix,spotify,leadiq,plaid
SMARTRECRUITERS_COMPANIES=Visa,Bosch,Ubisoft
ASHBY_BOARDS=Ramp,Linear,Notion
RECRUITEE_COMPANIES=recruitee,piktochart
# Remotive and Arbeitnow are fully public and need no configuration.


JWT_ACCESS_SECRET=YOUR JWR SECRET
JWT_REFRESH_SECRET=YOUR REFRESH SECRET
JWT_ACCESS_EXPIRY=25m
JWT_REFRESH_EXPIRY=7d

FRONTEND_URL=